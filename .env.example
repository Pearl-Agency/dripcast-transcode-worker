# Copy to your Railway service's Variables. All three are required.
# NOTE: no service-role key is needed — the worker only ever uses the anon key
# to push the finished file to a one-time signed upload URL.

# Both of these are in your Lovable repo at src/integrations/supabase/client.ts:
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-publishable-key

# A long random string. Set the SAME value as the TRANSCODE_SHARED_SECRET
# secret in Lovable Cloud (used by enqueue-transcode and transcode-callback).
TRANSCODE_SHARED_SECRET=generate-a-long-random-string

# Railway sets PORT automatically; this is only for local runs.
PORT=8080
